generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model SystemConfig {
  configKey   String   @id
  configValue String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("SystemConfig")
}

model UserPreference {
  authUserId        String        @id @map("auth_user_id")
  savedSignatureUrl String?       @map("saved_signature_url")
  signatureType     SignatureType? @map("signature_type")
  updatedAt         DateTime      @updatedAt

  @@map("user_preferences")
}

model Announcement {
  id                  String      @id @default(uuid())
  sourceSystem        String
  title               String
  content             String
  displayType         DisplayType @default(LIST)
  pushToCompanyCenter Boolean     @default(false)
  expiryDate          DateTime?
  startDate           DateTime?
  endDate             DateTime?
  spItemId            String?
  spWebUrl            String?
  spDownloadUrl       String?
  fileName            String?
  mimeType            String?
  bgColor             String?
  bgImageUrl          String?
  bgImageSpId         String?
  textColor           String?
  status              String      @default("ACTIVE")
  createdById         String
  createdByAuthUserId String?     @map("created_by_auth_user_id")
  createdByName       String?     @map("created_by_name")
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@map("Announcement")
}

model DarMaster {
  id            String            @id @default(uuid())
  darNo         String?           @unique
  requestDate   DateTime          @default(now())
  objective     String
  docType       String
  docTypeOther  String?
  reason        String
  spFolderId    String?
  spFolderPath  String?
  spDriveId     String?
  spItemId      String?
  spWebUrl      String?
  status                  DarStatus         @default(DRAFT)
  requesterId             String
  requesterAuthUserId     String?           @map("requester_auth_user_id")
  requesterName           String?           @map("requester_name")
  requesterEmployeeId     String?           @map("requester_employee_id")
  requesterEmail          String?           @map("requester_email")
  requesterDepartmentName String?           @map("requester_department_name")
  departmentId            String
  authDepartmentId        String?           @map("auth_department_id")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  approvals     DarApproval[]
  attachments   DarAttachment[]
  distributions DarDistribution[]
  items         DarItem[]
  qmsProcessing QmsProcessing?

  @@index([status])
  @@index([requesterId])
  @@index([departmentId])
  @@map("DarMaster")
}

model DarItem {
  id          String    @id @default(uuid())
  itemNo      Int
  docNumber   String
  docName     String
  revision    String
  darMasterId String
  darMaster   DarMaster @relation(fields: [darMasterId], references: [id], onDelete: Cascade)

  @@map("DarItem")
}

model DarDistribution {
  id               String    @id @default(uuid())
  darMasterId      String
  departmentId     String
  authDepartmentId String?   @map("auth_department_id")
  departmentName   String?   @map("department_name")
  darMaster        DarMaster @relation(fields: [darMasterId], references: [id], onDelete: Cascade)

  @@map("DarDistribution")
}

model DarAttachment {
  id            String    @id @default(uuid())
  fileName      String
  fileSize      Int
  mimeType      String
  spItemId      String
  spWebUrl      String
  spDownloadUrl String
  folderPath    String
  darMasterId          String
  uploadedById         String
  uploadedByAuthUserId String?   @map("uploaded_by_auth_user_id")
  uploadedByName       String?   @map("uploaded_by_name")
  createdAt            DateTime  @default(now())
  darMaster            DarMaster @relation(fields: [darMasterId], references: [id], onDelete: Cascade)
  // uploadedBy relation removed

  @@index([darMasterId])
  @@index([spItemId])
  @@map("DarAttachment")
}

model DarApproval {
  id                String         @id @default(uuid())
  stepRole          ApprovalStep
  action            ApprovalAction @default(PENDING)
  actionDate        DateTime?
  signatureUsedUrl  String?
  signatureTypeUsed SignatureType?
  darMasterId        String
  assignedUserId     String
  assignedAuthUserId String?        @map("assigned_auth_user_id")
  assignedUserName   String?        @map("assigned_user_name")
  assignedEmployeeId String?        @map("assigned_employee_id")
  assignedDepartmentName String?    @map("assigned_department_name")
  comment            String?
  darMaster          DarMaster      @relation(fields: [darMasterId], references: [id], onDelete: Cascade)

  @@index([darMasterId])
  @@index([assignedUserId])
  @@map("DarApproval")
}

model ApprovalSignature {
  id            String         @id @default(uuid())
  module        ApprovalModule
  documentId    String
  step          ApprovalStep
  action        ApprovalAction @default(PENDING)
  actionDate    DateTime?
  signerUserId     String
  signerAuthUserId String?        @map("signer_auth_user_id")
  signerName       String?        @map("signer_name")
  signerEmail      String?        @map("signer_email")
  signerDepartmentName String?    @map("signer_department_name")
  signaturePath    String?
  comment          String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([module, documentId])
  @@index([signerUserId])
  @@unique([module, documentId, step])
  @@map("ApprovalSignature")
}

model QmsProcessing {
  id                    String    @id @default(uuid())
  chkHasAttachment      Boolean   @default(false)
  chkPrintAndValidate   Boolean   @default(false)
  chkRenumber           Boolean   @default(false)
  chkImpactInvestigated Boolean   @default(false)
  chkSubmitVerification Boolean   @default(false)
  chkGetBackProcess     Boolean   @default(false)
  chkCopyDistribute     Boolean   @default(false)
  comments              String?
  processDate           DateTime?
  darMasterId        String    @unique
  qmsUserId          String
  qmsAuthUserId      String?   @map("qms_auth_user_id")
  qmsUserName        String?   @map("qms_user_name")
  qmsUserEmployeeId  String?   @map("qms_user_employee_id")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  darMaster          DarMaster @relation(fields: [darMasterId], references: [id], onDelete: Cascade)

  @@map("QmsProcessing")
}

model PublicDocument {
  id            String   @id @default(uuid())
  darMasterId   String?
  docNumber     String
  docName       String
  revision      String
  spDriveId     String
  spItemId      String
  spFolderPath  String?
  spWebUrl      String
  publishedDate DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("PublicDocument")
}

model KPI {
  id                String             @id @default(uuid())
  yearly            Int
  department        String
  prepare           String
  reviewer          String
  approver          String
  status            KpiObjectiveStatus @default(DRAFT)
  prepareSignature  String?            @map("prepare_signature") @db.Text
  reviewerUserId        String?            @map("reviewer_user_id")
  reviewerAuthUserId    String?            @map("reviewer_auth_user_id")
  reviewerEmail         String?            @map("reviewer_email")
  approverUserId        String?            @map("approver_user_id")
  approverAuthUserId    String?            @map("approver_auth_user_id")
  approverEmail         String?            @map("approver_email")
  submittedAt       DateTime?          @map("submitted_at")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  objectives        KPIObjective[]
  monthlyReports    KPIMonthlyReport[]

  @@unique([department, yearly])
  @@map("kpis")
}

model KPIObjective {
  id                   String             @id @default(uuid())
  kpiId                String             @map("kpi_id")
  target               Float
  unit                 String?
  objective            String             @db.Text
  frequency            String
  calculationFormula   String             @map("calculation_formula") @db.Text
  actionPlanGuidelines String             @map("action_plan_guidelines") @db.Text
  referenceDocuments   String?            @map("reference_documents") @db.Text
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  kpi                  KPI                @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  monthlyDetails       KPIMonthlyDetail[]

  @@map("kpi_objectives")
}

model KPIMonthlyReport {
  id          String             @id @default(uuid())
  kpiId       String             @map("kpi_id")
  month       String
  year        Int
  status      MonthlyStatus      @default(DRAFT)
  prepareBy   String?            @map("prepare_by")
  reviewBy    String?            @map("review_by")
  approveBy   String?            @map("approve_by")
  submittedAt DateTime?          @map("submitted_at")
  approvedAt  DateTime?          @map("approved_at")
  remark      String?            @db.Text
  attachmentFileName String?     @map("attachment_file_name")
  attachmentFileSize Int?        @map("attachment_file_size")
  attachmentMimeType String?     @map("attachment_mime_type")
  attachmentSpItemId String?     @map("attachment_sp_item_id")
  attachmentWebUrl String?       @map("attachment_web_url") @db.Text
  attachmentDownloadUrl String?  @map("attachment_download_url") @db.Text
  attachmentUploadedAt DateTime? @map("attachment_uploaded_at")
  attachmentUploadedBy String?   @map("attachment_uploaded_by")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  kpi         KPI                @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  details     KPIMonthlyDetail[]

  @@unique([kpiId, month, year])
  @@map("kpi_monthly_reports")
}

model KPIMonthlyDetail {
  id                String                @id @default(uuid())
  monthlyReportId   String                @map("monthly_report_id")
  kpiObjectiveId    String                @map("kpi_objective_id")
  actualResult      Float?                @map("actual_result")
  achievedStatus    AchievedStatus        @default(PENDING)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  monthlyReport     KPIMonthlyReport      @relation(fields: [monthlyReportId], references: [id], onDelete: Cascade)
  kpiObjective      KPIObjective          @relation(fields: [kpiObjectiveId], references: [id], onDelete: Restrict)
  correctiveActions KPICorrectiveAction[]

  @@unique([monthlyReportId, kpiObjectiveId])
  @@map("kpi_monthly_details")
}

model KPICorrectiveAction {
  id                String           @id @default(uuid())
  monthlyDetailId   String           @map("monthly_detail_id")
  times             Int
  rootCause         String           @map("root_cause") @db.Text
  guidelines        String           @db.Text
  responsiblePerson String           @map("responsible_person")
  dueDate           DateTime         @map("due_date")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  monthlyDetail     KPIMonthlyDetail @relation(fields: [monthlyDetailId], references: [id], onDelete: Cascade)

  @@map("kpi_corrective_actions")
}

enum UserRole {
  USER
  IT
  QMS
  MR
}

enum DisplayType {
  LIST
  SCROLLING
  BANNER
}

enum DarStatus {
  DRAFT
  PENDING_REVIEW
  PENDING_APPROVE
  QMS_PROCESSING
  COMPLETED
  CANCELLED
}

enum ApprovalAction {
  PENDING
  APPROVED
  REJECTED
}

enum ApprovalStep {
  REQUESTER
  REQUESTER_MANAGER
  PREPARER
  REVIEWER
  APPROVER
  APPROVER_MR
  APPROVER_DCC
  QMS_PROCESSOR
  // Audit sign-off steps
  LEAD_AUDITOR
  AUDIT_SIGNER
}

enum ApprovalModule {
  DAR
  KPI
  KPI_MONTHLY
  CAR
  AUDIT
}

enum CarStatus {
  DRAFT
  ISSUED
  RESPONDED
  VERIFY_1
  VERIFY_2
  CLOSED
  RE_CAR
  CANCELLED
}

enum CarSourceType {
  I
  C
  N
  O
}

enum VerificationResult {
  PASSED
  FAILED
}

enum SignatureType {
  DRAW
  TYPE
  IMAGE
}

enum KpiObjectiveStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum MonthlyStatus {
  DRAFT
  PENDING_REVIEW
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum AchievedStatus {
  PENDING
  OK
  NOT_OK
}

model DocumentControl {
  id            String           @id @default(uuid())
  docNumber     String           @unique
  docName       String
  revision      String?
  description   String?
  status        DocControlStatus @default(DRAFT)
  effectiveDate DateTime?
  spDriveId     String?
  spItemId      String?
  spWebUrl      String?
  spDownloadUrl String?
  spFolderPath  String?
  fileName      String?
  fileSize      Int?
  mimeType      String?
  createdById          String
  createdByAuthUserId  String?          @map("created_by_auth_user_id")
  createdByName        String?          @map("created_by_name")
  updatedById          String?
  updatedByAuthUserId  String?          @map("updated_by_auth_user_id")
  updatedByName        String?          @map("updated_by_name")
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  departmentId         String?
  authDepartmentId     String?           @map("auth_department_id")
  departmentName       String?           @map("department_name")
  categoryId   String?
  category     DocumentCategory?         @relation(fields: [categoryId], references: [id])
  revisions    DocumentControlRevision[]

  @@index([status])
  @@index([categoryId])
  @@index([createdById])
  @@index([departmentId])
  @@map("DocumentControl")
}

model DocumentCategory {
  id               String   @id @default(uuid())
  name             String
  description      String?
  order            Int      @default(0)
  departmentId     String
  authDepartmentId String?  @map("auth_department_id")
  departmentName   String?  @map("department_name")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  documents  DocumentControl[]

  @@unique([departmentId, name])
  @@index([departmentId])
  @@map("DocumentCategory")
}

model DocumentControlRevision {
  id                String           @id @default(uuid())
  documentControlId String
  revision          String
  effectiveDate     DateTime?
  status            DocControlStatus @default(ACTIVE)
  spDriveId         String?
  spItemId          String?
  spWebUrl          String?
  spDownloadUrl     String?
  spFolderPath      String?
  fileName          String?
  fileSize          Int?
  mimeType          String?
  createdById         String
  createdByAuthUserId String?          @map("created_by_auth_user_id")
  createdByName       String?          @map("created_by_name")
  createdAt           DateTime         @default(now())

  documentControl DocumentControl @relation(fields: [documentControlId], references: [id], onDelete: Cascade)

  @@index([documentControlId])
  @@index([status])
  @@map("DocumentControlRevision")
}

enum DocControlStatus {
  DRAFT
  ACTIVE
  OBSOLETE
}

model AuditLog {
  id              String   @id @default(uuid())
  actorUserId     String   @map("actor_user_id")
  actorAuthUserId String?  @map("actor_auth_user_id")
  actorRole       String   @map("actor_role")
  action       String   // CREATE | UPDATE | DELETE | APPROVE | REJECT | RECALL | SYNC | EXPORT | ROLE_CHANGE
  resourceType String   @map("resource_type") // KPI | DAR | USER | DOCUMENT | DOCUMENT_CATEGORY
  resourceId   String   @map("resource_id")
  before       Json?    // snapshot before change
  after        Json?    // snapshot after change
  metadata     Json?    // requestId, ip, source, etc.
  createdAt    DateTime @default(now())

  @@index([resourceType, resourceId])
  @@index([actorUserId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

model NotificationLog {
  id             String    @id @default(uuid())
  idempotencyKey String    @unique @map("idempotency_key")
  channel        String    @default("EMAIL") // EMAIL | PUSH
  status         String    @default("PENDING") // PENDING | SENT | FAILED
  recipient      String
  subject        String?
  errorMessage   String?   @map("error_message")
  attempts       Int       @default(0)
  sentAt         DateTime? @map("sent_at")
  createdAt      DateTime  @default(now())

  @@index([status])
  @@index([createdAt])
  @@map("notification_logs")
}

model Notification {
  id                  String   @id @default(uuid())
  recipientId         String   @map("recipient_id")
  recipientAuthUserId String?  @map("recipient_auth_user_id")
  title               String
  body                String
  module              String
  resourceId          String   @map("resource_id")
  resourceType        String   @map("resource_type")
  isRead              Boolean  @default(false) @map("is_read")
  createdAt           DateTime @default(now())

  @@index([recipientId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model ActionToken {
  id         String         @id @default(cuid())
  token      String         @unique
  module     ApprovalModule
  documentId String
  role       ApprovalStep
  issuedTo   String         // Auth Center authUserId
  metadata   Json?
  expiresAt  DateTime
  usedAt     DateTime?
  revokedAt  DateTime?
  createdAt  DateTime       @default(now())

  @@index([token])
  @@index([documentId, module])
  @@index([expiresAt])
  @@map("action_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAR Domain
// ─────────────────────────────────────────────────────────────────────────────

model CarMaster {
  id                 String               @id @default(uuid())
  carNo              String               @unique
  carYear            Int
  sequenceNo         Int
  status             CarStatus            @default(DRAFT)
  sourceType         CarSourceType
  sourceDetail       String?
  isoStandards       String[]
  defectDetail       String
  nonConformanceRef  String
  issuerId               String
  issuerAuthUserId       String?              @map("issuer_auth_user_id")
  issuerName             String?              @map("issuer_name")
  issuerEmployeeId       String?              @map("issuer_employee_id")
  issuerPosition         String
  issuedAt               DateTime?
  targetDepartmentId     String
  targetAuthDepartmentId String?              @map("target_auth_department_id")
  targetDepartmentName   String?              @map("target_department_name")
  targetEmailGroups      String[]
  targetEmailGroupsCc    String[]             @default([]) @map("target_email_groups_cc")
  responseDueAt      DateTime?
  reCar              Boolean              @default(false)
  reCarRefId         String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  reCarRef           CarMaster?           @relation("ReCarRef", fields: [reCarRefId], references: [id])
  reCarChildren      CarMaster[]          @relation("ReCarRef")
  response             CarResponse?
  verifications        CarVerification[]
  mrSignature          CarMrSignature?
  mrResponseReview     CarMrResponseReview?
  notificationLogs     CarNotificationLog[]

  @@index([status])
  @@index([issuerId])
  @@index([targetDepartmentId])
  @@index([carYear, sequenceNo])
  @@map("CarMaster")
}

model CarResponse {
  id                   String          @id @default(uuid())
  carMasterId           String          @unique
  responderId           String
  responderAuthUserId   String?         @map("responder_auth_user_id")
  responderName         String?         @map("responder_name")
  responderEmployeeId   String?         @map("responder_employee_id")
  responderPosition     String
  respondedAt          DateTime        @default(now())
  whyAnalysis          String
  additionalToolDetail String?
  rootCausePerson      Boolean         @default(false)
  rootCauseMaterial    Boolean         @default(false)
  rootCauseMachine     Boolean         @default(false)
  rootCauseMethod      Boolean         @default(false)
  rootCauseOther       Boolean         @default(false)
  rootCauseOtherDetail String?
  rootCauseSummary     String
  immediateAction      String
  preventiveAction     String
  plannedCompletionDate DateTime

  carMaster            CarMaster       @relation(fields: [carMasterId], references: [id], onDelete: Cascade)
  attachments          CarAttachment[]

  @@map("CarResponse")
}

model CarVerification {
  id               String             @id @default(uuid())
  carMasterId         String
  round               Int
  verifierId          String
  verifierAuthUserId  String?            @map("verifier_auth_user_id")
  verifierName        String?            @map("verifier_name")
  verifierEmployeeId  String?            @map("verifier_employee_id")
  verifierPosition    String
  verifiedAt       DateTime           @default(now())
  findings         String
  result           VerificationResult
  nextDueDate      DateTime?

  carMaster        CarMaster          @relation(fields: [carMasterId], references: [id], onDelete: Cascade)

  @@unique([carMasterId, round])
  @@map("CarVerification")
}

model CarMrSignature {
  id          String    @id @default(uuid())
  carMasterId    String    @unique
  mrUserId       String
  mrAuthUserId   String?   @map("mr_auth_user_id")
  mrUserName     String?   @map("mr_user_name")
  mrEmployeeId   String?   @map("mr_employee_id")
  signedAt       DateTime  @default(now())
  comment        String?

  carMaster   CarMaster @relation(fields: [carMasterId], references: [id], onDelete: Cascade)

  @@map("CarMrSignature")
}

model CarAttachment {
  id            String      @id @default(uuid())
  carResponseId String
  fileName      String
  fileSize      Int
  mimeType      String
  spItemId      String
  spWebUrl      String
  spDownloadUrl String
  folderPath    String
  uploadedById         String
  uploadedByAuthUserId String?     @map("uploaded_by_auth_user_id")
  uploadedByName       String?     @map("uploaded_by_name")
  createdAt            DateTime    @default(now())

  carResponse   CarResponse @relation(fields: [carResponseId], references: [id], onDelete: Cascade)

  @@index([carResponseId])
  @@map("CarAttachment")
}

model CarMrResponseReview {
  id          String    @id @default(uuid())
  carMasterId  String    @unique
  mrUserId     String
  mrAuthUserId String?   @map("mr_auth_user_id")
  mrUserName   String?   @map("mr_user_name")
  mrEmployeeId String?   @map("mr_employee_id")
  reviewedAt   DateTime  @default(now())
  action       String    // "APPROVED" | "REJECTED"
  comment      String?

  carMaster   CarMaster @relation(fields: [carMasterId], references: [id], onDelete: Cascade)

  @@map("CarMrResponseReview")
}

model CarNotificationLog {
  id          String    @id @default(uuid())
  carMasterId String
  type        String
  sentAt      DateTime  @default(now())
  recipient   String

  carMaster   CarMaster @relation(fields: [carMasterId], references: [id], onDelete: Cascade)

  @@index([carMasterId])
  @@map("CarNotificationLog")
}

