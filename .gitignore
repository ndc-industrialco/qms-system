# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# cloudflare / opennext
/.open-next/

# production
/build

# misc
.DS_Store
*.pem

# kilo AI - runtime data (config files themselves are committed)
.kilo/node_modules/
.kilo/data/
.kilo/sessions/
.kilo/worktrees/
.kilo/cache/
.kilo/package.json
.kilo/package-lock.json

# kilo AI - built-in agent skills (not project source)
.agents/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma
